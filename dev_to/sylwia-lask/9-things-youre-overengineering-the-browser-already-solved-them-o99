<div class="highlight js-code-highlight">
<pre class="highlight html"><code><span class="nt">&lt;div</span> <span class="na">class=</span><span class="s">"form-field"</span><span class="nt">&gt;</span>
  <span class="nt">&lt;input</span> <span class="na">placeholder=</span><span class="s">"Type something meaningful..."</span> <span class="nt">/&gt;</span>
