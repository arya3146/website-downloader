ent\",\"tagName\":\"h2\",\"properties\":{},\"children\":[{\"type\":\"text\",\"value\":\"Does Better Prompting Make AI Output Better?\",\"position\":{\"start\":{\"line\":9,\"column\":4,\"offset\":581},\"end\":{\"line\":9,\"column\":48,\"offset\":625}}}],\"position\":{\"start\":{\"line\":9,\"column\":1,\"offset\":578},\"end\":{\"line\":9,\"column\":48,\"offset\":625}}},\"children\":\"Does Better Prompting Make AI Output Better?\"}],\"\\n\",[\"$\",\"p\",\"p-2\",{\"children\":\"Short answer: No.\\nPrompts alone stop AI slop in roughly 80% of generations. The remaining 20% is where production reputation lives. Our fix for this is a code-side validator that scans every draft against a structured banned lexicon, runs four detection passes (vocabulary, phrases, openers, regex structures), and triggers one bounded repaired retry on slop. Worst case is that the latency (time-to-output) goes from N seconds to roughly 2N. The average latency is unchanged, and the user gets a draft that does not read like ChatGPT.\"}],\"\\n\",[\"$\",\"h2\",\"h2-1\",{\"id\":\"what-is-ai-slop-and-why-does-it-slip-past-prompt-rules\",\"className\":\"scroll-mt-24\",\"node\":{\"type\":\"element\",\"tagName\":\"h2\",\"properties\":{},\"children\":[{\"type\":\"text\",\"value\":\"What is \\\"AI slop\\\" and why does it slip past prompt rules?\",\"position\":{\"start\":{\"line\":13,\"column\":4,\"offset\":1166},\"end\":{\"line\":13,\"column\":61,\"offset\":1223}}}],\"position\":{\"start\":{\"line\":13,\"column\":1,\"offset\":1163},\"end\":{\"line\":13,\"column\":61,\"offset\":1223}}},\"children\":\"What is \\\"AI slop\\\" and why does it slip past prompt rules?\"}],\"\\n\",\"$L2b\",\"\\n\",\"$L2c\",\"\\n\",\"$L2d\",\"\\n\",\"$L2e\",\"\\n\",\"$L2f\",\"\\n\",\"$L30\",\"\\n\",\"$L31\",\"\\n\",\"$L32\",\"\\n\",\"$L33\",\"\\n\",\"$L34\",\"\\n\",\"$L35\",\"\\n\",\"$L36\",\"\\n\",\"$L37\",\"\\n\",\"$L38\",\"\\n\",\"$L39\",\"\\n\",\"$L3a\",\"\\n\",\"$L3b\",\"\\n\",\"$L3c\",\"\\n\",\"$L3d\",\"\\n\",\"$L3e\",\"\\n