<script>
  // Define carousel component
  document.addEventListener('alpine:init', () => {
      Alpine.data('carousel', (numberOfSlides) => ({
        slide: 0,
        slides: numberOfSlides,
        lightbox: false,
        lightboxSlide: 0,
        touchX: null,
        next() {
          if (this.lightbox) { this.nextLightbox(); return; }
          if (this.slide < this.slides) this.slide++;
        },
        prev() {
          if (this.lightbox) { this.previousLightbox(); return; }
          if (this.slide > 0) this.slide--;
        },
        openLightbox(slideNumber) {
          console.log(slideNumber)
          this.lightbox = true;
          this.lightboxSlide = slideNumber;
        },
        closeLightbox() {
          this.lightbox = false;
          this.lightboxSlide = 0
        },
        nextLightbox() {
          if (this.lightboxSlide < this.slides) this.lightboxSlide++;
        },
        previousLightbox() {
          if (this.lightboxSlide > 0) this.lightboxSlide--;
        },
        touchStart(e) {
          this.touchX = e.touches[0].screenX;
        },
        touch(e) {
          if (this.touchX) {
            if (e.touches[0].screenX - this.touchX > 75) this.prev()
            else if (this.touchX - e.touches[0].screenX > 75) this.next()
          }
        },
        touchEnd(e) {
          this.touchX = null;
        }
      }));

      // Define platforms component for showcase platform/app links
      Alpine.data('platforms', () => ({
        // State
        open: false,
        // Methods
        toggle() {
          this.open = !this.open;
        },
        // Initialization
        init() {
          // Close dropdown when clicking outside
          document.addEventListener('click', (e) => {
            if (!this.$el.contains(e.target)) {
              this.open = false;
            }
          });
          // Close dropdown on escape key
          document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') {
              this.open = false;
            }
          });
        }
      }));
  })
</script>

